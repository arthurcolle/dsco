{
  "template": "mortgage_desk_daily",
  "desc": "ABS / mortgage desk \u2014 one trading day as a multi-agent flow. Personas are the deal's REAL underwriting firms, sourced from the 424B5 syndicate list in the deal database (the underwriter table); no individual trader names are used because SEC ABS filings disclose firms, not desk individuals. The desk pulls its live collateral book + syndicate from the DB (sqlite seam), each firm-persona's decision threads into the next, and every decision is committed to a tamper-evident hash-chained ledger.",
  "ledger": "mortgage_desk.chain.jsonl",
  "provenance": "agents = real underwriters of WORLD OMNI AUTO RECEIVABLES TRUST 2024-C per its 424B5; roles are desk-function categories, not named individuals. | grounded: each firm-persona bound to a real FINRA-registered individual (CRD) at that firm via the BrokerCheck mirror.",
  "agents": [
    {
      "name": "Wells Fargo Securities",
      "firm": "Wells Fargo Securities",
      "role": "Lead Manager / Structuring desk",
      "trajectory": [
        "set_levels"
      ],
      "owns": "morning markup \u2014 coupon stack, TBA levels, desk axe, risk envelope",
      "firm_crd": 7665,
      "crd": 272705,
      "individual": "RODNEY EARL KNOX"
    },
    {
      "name": "BofA Securities",
      "firm": "BofA Securities",
      "role": "Lead Manager / Syndicate",
      "trajectory": [
        "price_pool"
      ],
      "owns": "pool pricing \u2014 spread, hedge ratio, fair value vs the desk levels",
      "firm_crd": 283942,
      "crd": 206879,
      "individual": "MARC FERRO"
    },
    {
      "name": "Barclays",
      "firm": "Barclays",
      "role": "Lead Manager / Trading desk",
      "trajectory": [
        "rfq"
      ],
      "owns": "client/street RFQ \u2014 bid-wanted into the desk's quoted pool",
      "firm_crd": 19714,
      "crd": 419623,
      "individual": "MARTIN DONALD SHAFIROFF"
    },
    {
      "name": "Truist Securities",
      "firm": "Truist Securities",
      "role": "Lead Manager / Execution",
      "trajectory": [
        "execute_hedge"
      ],
      "owns": "execution \u2014 TBA roll hedge, fill the RFQ, book and record the trade",
      "firm_crd": 6271,
      "crd": 703894,
      "individual": "RICHARD EDWIN BARRON"
    }
  ],
  "steps": [
    {
      "kind": "sqlite",
      "config": {
        "path": "data/cmo/cmo.db"
      },
      "method": "query",
      "params": {
        "sql": "SELECT DISTINCT u.name AS underwriter, u.role FROM underwriter u JOIN deal_identity i ON i.accession=u.accession WHERE i.deal_key LIKE 'WORLD OMNI%' ORDER BY u.role,u.name",
        "limit": 50
      }
    },
    {
      "agent": "Wells Fargo Securities",
      "kind": "agent",
      "config": {
        "name": "Wells Fargo Securities",
        "firm": "Wells Fargo Securities",
        "role": "Lead Manager / Structuring desk",
        "firm_crd": 7665,
        "crd": 272705,
        "individual": "RODNEY EARL KNOX"
      },
      "method": "set_levels",
      "params": {
        "session": "2026-06-08",
        "coupon": 5.5,
        "tba_px": "99-16",
        "axe": "better seller 30y UMBS 5.5",
        "risk_limit_usd": 50000000,
        "syndicate": "{{step1}}"
      }
    },
    {
      "kind": "chain",
      "config": {
        "path": "mortgage_desk.chain.jsonl"
      },
      "method": "append",
      "params": {
        "data": "{{step2}}"
      }
    },
    {
      "agent": "BofA Securities",
      "kind": "agent",
      "config": {
        "name": "BofA Securities",
        "firm": "BofA Securities",
        "role": "Lead Manager / Syndicate",
        "firm_crd": 283942,
        "crd": 206879,
        "individual": "MARC FERRO"
      },
      "method": "price_pool",
      "params": {
        "pool": "FN CK1234",
        "oas_bp": 24,
        "hedge_ratio": 0.92,
        "fair_px": "100-02",
        "upstream_levels": "{{step2:decision}}"
      }
    },
    {
      "kind": "chain",
      "config": {
        "path": "mortgage_desk.chain.jsonl"
      },
      "method": "append",
      "params": {
        "data": "{{step4}}"
      }
    },
    {
      "agent": "Barclays",
      "kind": "agent",
      "config": {
        "name": "Barclays",
        "firm": "Barclays",
        "role": "Lead Manager / Trading desk",
        "firm_crd": 19714,
        "crd": 419623,
        "individual": "MARTIN DONALD SHAFIROFF"
      },
      "method": "rfq",
      "params": {
        "side": "bid_wanted",
        "cusip": "31418XYZ7",
        "size_mm": 25,
        "vs_pricing": "{{step4:decision}}"
      }
    },
    {
      "kind": "chain",
      "config": {
        "path": "mortgage_desk.chain.jsonl"
      },
      "method": "append",
      "params": {
        "data": "{{step6}}"
      }
    },
    {
      "agent": "Truist Securities",
      "kind": "agent",
      "config": {
        "name": "Truist Securities",
        "firm": "Truist Securities",
        "role": "Lead Manager / Execution",
        "firm_crd": 6271,
        "crd": 703894,
        "individual": "RICHARD EDWIN BARRON"
      },
      "method": "execute_hedge",
      "params": {
        "instrument": "TBA UMBS 5.5 Jul",
        "action": "sell",
        "notional_mm": 23,
        "booked": true,
        "hedge_from": "{{step4:decision}}",
        "fill_rfq": "{{step6:decision}}"
      }
    },
    {
      "kind": "chain",
      "config": {
        "path": "mortgage_desk.chain.jsonl"
      },
      "method": "append",
      "params": {
        "data": "{{step8}}"
      }
    }
  ]
}
